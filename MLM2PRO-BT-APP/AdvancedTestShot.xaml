<Window x:Class="MLM2PRO_BT_APP.AdvancedTestShot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLM2PRO_BT_APP"
        mc:Ignorable="d"
        Title="Advanced Test Shot" Height="700" Width="900"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Club Buttons -->
        <GroupBox Grid.Row="0" Header="Club Selection" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="8" HorizontalAlignment="Left">
                <Button Width="70" Margin="4" Content="Driver" Click="Club_Click" Tag="Driver"/>
                <Button Width="70" Margin="4" Content="3 Wood" Click="Club_Click" Tag="3W"/>
                <Button Width="70" Margin="4" Content="5 Wood" Click="Club_Click" Tag="5W"/>
                <Button Width="70" Margin="4" Content="5 Iron" Click="Club_Click" Tag="5I"/>
                <Button Width="70" Margin="4" Content="6 Iron" Click="Club_Click" Tag="6I"/>
                <Button Width="70" Margin="4" Content="7 Iron" Click="Club_Click" Tag="7I"/>
                <Button Width="70" Margin="4" Content="8 Iron" Click="Club_Click" Tag="8I"/>
                <Button Width="70" Margin="4" Content="9 Iron" Click="Club_Click" Tag="9I"/>
                <Button Width="60" Margin="4" Content="PW" Click="Club_Click" Tag="PW"/>
                <Button Width="60" Margin="4" Content="SW" Click="Club_Click" Tag="SW"/>
                <Button Width="60" Margin="4" Content="LW" Click="Club_Click" Tag="LW"/>
            </StackPanel>
        </GroupBox>

        <!-- Distance Buttons -->
        <GroupBox Grid.Row="1" Header="Distance Shots" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="8" HorizontalAlignment="Left">
                <Button Width="100" Margin="4" Content="20 Yard" Click="Distance_Click" Tag="20"/>
                <Button Width="100" Margin="4" Content="30 Yard" Click="Distance_Click" Tag="30"/>
                <Button Width="100" Margin="4" Content="40 Yard" Click="Distance_Click" Tag="40"/>
                <Button Width="100" Margin="4" Content="50 Yard" Click="Distance_Click" Tag="50"/>
            </StackPanel>
        </GroupBox>

        <!-- Custom Shot Sliders -->
        <GroupBox Grid.Row="2" Header="Custom Shot Configuration" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Ball Speed (MPH)"/>
                <Slider x:Name="BallSpeedSlider" Grid.Row="0" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="200" Value="145" VerticalAlignment="Center"/>
                <TextBlock x:Name="BallSpeedValue" Grid.Row="0" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="145"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Spin Axis"/>
                <Slider x:Name="SpinAxisSlider" Grid.Row="1" Grid.Column="1" Margin="8,4" Minimum="-3" Maximum="3" Value="0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SpinAxisValue" Grid.Row="1" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Total Spin (RPM)"/>
                <Slider x:Name="TotalSpinSlider" Grid.Row="2" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="13000" Value="5000" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalSpinValue" Grid.Row="2" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="5000"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Back Spin (RPM)"/>
                <Slider x:Name="BackSpinSlider" Grid.Row="3" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="13000" Value="5000" VerticalAlignment="Center"/>
                <TextBlock x:Name="BackSpinValue" Grid.Row="3" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="5000"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Side Spin (RPM)"/>
                <Slider x:Name="SideSpinSlider" Grid.Row="4" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="5000" Value="0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SideSpinValue" Grid.Row="4" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="0"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="HLA"/>
                <Slider x:Name="HlaSlider" Grid.Row="5" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="40" Value="0" VerticalAlignment="Center"/>
                <TextBlock x:Name="HlaValue" Grid.Row="5" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="0"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="VLA"/>
                <Slider x:Name="VlaSlider" Grid.Row="6" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="40" Value="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="VlaValue" Grid.Row="6" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="16"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,4" VerticalAlignment="Center" Text="Club Speed (MPH)"/>
                <Slider x:Name="ClubSpeedSlider" Grid.Row="7" Grid.Column="1" Margin="8,4" Minimum="0" Maximum="150" Value="105" VerticalAlignment="Center"/>
                <TextBlock x:Name="ClubSpeedValue" Grid.Row="7" Grid.Column="2" Margin="4,4" VerticalAlignment="Center" Text="105"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <CheckBox x:Name="PretendSquareGolfCheckBox"
                          VerticalAlignment="Center"
                          Content="Pretend to be SquareGolf"
                          Checked="PretendSquareGolfCheckBox_Changed"
                          Unchecked="PretendSquareGolfCheckBox_Changed"/>
                <CheckBox x:Name="LogSquareGolfHeartbeatCheckBox"
                          Margin="0,6,0,0"
                          VerticalAlignment="Center"
                          Content="Log SquareGolf heartbeat messages"
                          Checked="LogSquareGolfHeartbeatCheckBox_Changed"
                          Unchecked="LogSquareGolfHeartbeatCheckBox_Changed"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_Click"/>
                <Button Width="90" Content="Send" Click="Send_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>